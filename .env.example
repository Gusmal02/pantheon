# Pantheon v2.1 — Variables de entorno (copiar a .env y completar)

# ── Secrets (generar con: python -c "import secrets; print(secrets.token_hex(32))")
PANTHEON_JWT_SECRET=
PANTHEON_ENCLAVE_KEY=
PANTHEON_JWT_EXPIRE_HOURS=1

# ── PostgreSQL
POSTGRES_USER=pantheon
POSTGRES_PASSWORD=
POSTGRES_DB=pantheon
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ── Redis (puerto 6380 para no colisionar con Ares en 6379)
REDIS_URL=redis://localhost:6380

# ── Qdrant (puertos 6335-6336 para no colisionar con Ares en 6333-6334)
QDRANT_HOST=localhost
QDRANT_PORT=6335
QDRANT_COLLECTION_EPISODES=pantheon_episodes

# ── WORM (S3-compatible)
WORM_ENDPOINT=http://localhost:9000/pantheon-audit
WORM_TIMEOUT_SECS=5
WORM_ENABLED=0

# ── Audit
PANTHEON_ENCLAVE_LOG=audit/precommit.log
PANTHEON_OUTBOX_POLL_SECS=5

# ── CCI thresholds
CCI_AMBIGUOUS_THRESHOLD=0.45
CCI_CRITICAL_THRESHOLD=0.75

# ── Input Guard
INPUT_GUARD_RATE_LIMIT=50
INPUT_GUARD_CB_COOLDOWN_SECS=30

# ── Approval Gate
PANTHEON_APPROVAL_TIMEOUT_SECS=600

# ── Purple Team (integración con Ares)
ARES_API_URL=http://localhost:8000
ARES_POLL_CB_FAILURES=5

# ── Ollama (LLM local para Hermes — opcional)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── Rate Limiting de la API REST
API_RATE_LIMIT=120
